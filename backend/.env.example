# PostgreSQL connection string
# Local example: postgresql://postgres:yourpassword@localhost:5432/appointy
# Neon/Supabase/Railway: copy the connection string from your dashboard
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/appointy

# Set to true if your PostgreSQL provider requires SSL (e.g. Neon, Supabase)
DATABASE_SSL=false

# JWT secret (any long random string)
JWT_SECRET=your_jwt_secret_here

# Cloudinary credentials (https://cloudinary.com/console)
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_SECRET_KEY=your_cloudinary_secret_key

# Admin credentials (hardcoded login, not stored in DB)
ADMIN_EMAIL=admin@appointy.com
ADMIN_PASSWORD=admin123456

# Razorpay credentials (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Currency for Razorpay
CURRENCY=INR

# Server port
PORT=4000
